<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <title>UniEnroll • Student</title>
    <style>
        :root{
            --bg:#0b1220;
            --card:#111a2e;
            --text:#e9eefc;
            --muted:#a9b4d0;
            --accent:#7c5cff;
            --accent2:#22c55e;
            --danger:#ef4444;
            --border:rgba(255,255,255,.10);
        }
        *{box-sizing:border-box}
        body{
            margin:0;
            font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
            background: radial-gradient(1000px 600px at 20% 10%, rgba(124,92,255,.35), transparent 60%),
            radial-gradient(900px 550px at 85% 25%, rgba(34,197,94,.25), transparent 55%),
            var(--bg);
            color:var(--text);
            min-height:100vh;
            display:flex;
            align-items:center;
            justify-content:center;
        }
        .card{
            width:100%;
            max-width:480px;
            margin:24px;
            border:1px solid var(--border);
            border-radius:24px;
            background: rgba(17,26,46,.85);
            backdrop-filter: blur(12px);
            padding:48px;
            text-align:center;
        }
        .avatar{
            width:80px;
            height:80px;
            background: linear-gradient(135deg, var(--accent), #3b82f6);
            border-radius:50%;
            margin:0 auto 24px;
            display:flex;
            align-items:center;
            justify-content:center;
            font-size:36px;
        }
        .h1{font-size:28px;margin:0 0 12px;font-weight:700}
        .sub{color:var(--muted);margin:0 0 32px;font-size:16px;line-height:1.6}
        .btn{
            padding:14px 32px;
            border:1px solid transparent;
            border-radius:12px;
            cursor:pointer;
            font-weight:600;
            font-size:15px;
            background: transparent;
            border-color: var(--border);
            color: var(--text);
            transition:all 0.2s;
        }
        .btn:hover{
            border-color: var(--accent);
            color: var(--accent);
        }
    </style>
</head>
<body>
<div class="card">
    <div class="avatar">👤</div>
    <h1 class="h1">Welcome, Student</h1>
    <p class="sub">Student portal access confirmed.<br>Course enrollment features coming soon.</p>

    <form method="post" action="/logout">
        <button class="btn" type="submit">Sign Out</button>
    </form>
</div>
</body>
</html>