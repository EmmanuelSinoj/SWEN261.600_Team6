<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <title>UniEnroll • {{pageTitle}}</title>
    <style>
        :root{
            --bg:#0b1220; --card:#111a2e; --text:#e9eefc; --muted:#a9b4d0;
            --accent:#7c5cff; --border:rgba(255,255,255,.10);
        }
        *{box-sizing:border-box}
        body{
            margin:0; font-family: system-ui, -apple-system, sans-serif;
            background: var(--bg); color:var(--text); min-height:100vh;
            display: flex; flex-direction: column;
        }
        /* -- COPY THE EXACT NAVBAR CSS FROM STUDENT.HTML HERE -- */
        .navbar { display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 2rem; background: rgba(17,26,46,.95); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; backdrop-filter: blur(10px); }
        .nav-brand { font-size: 1.25rem; font-weight: bold; color: var(--text); text-decoration: none; }
        .nav-brand span { color: var(--accent); }
        .nav-links { display: flex; gap: 1.5rem; }
        .nav-link { color: var(--muted); text-decoration: none; font-size: 0.95rem; font-weight: 500; padding: 0.5rem 0; border-bottom: 2px solid transparent; transition: all 0.2s; }
        .nav-link:hover { color: var(--text); }
        .nav-link.active { color: var(--text); border-bottom-color: var(--accent); }
        .btn-logout { background: transparent; color: var(--muted); border: 1px solid var(--border); padding: 0.4rem 0.8rem; border-radius: 8px; cursor: pointer; font-size: 0.85rem; }
        .btn-logout:hover { border-color: var(--accent); color: var(--text); }

        /* Layout for the coming soon message */
        .content {
            flex-grow: 1; display: flex; align-items: center; justify-content: center;
            text-align: center; padding: 2rem;
        }
        .message-box {
            background: rgba(17,26,46,.85); border: 1px solid var(--border);
            padding: 3rem; border-radius: 16px; max-width: 500px;
        }
        .icon { font-size: 3rem; margin-bottom: 1rem; }
    </style>
</head>
<body>

<nav class="navbar">
    <a href="/student" class="nav-brand">Uni<span>Enroll</span></a>

    <div class="nav-links">
        <a href="/student" class="nav-link {{#navCatalog}}active{{/navCatalog}}">Catalog</a>
        <a href="/student/cart" class="nav-link {{#navCart}}active{{/navCart}}">Cart</a>
        <a href="/student/enrolled" class="nav-link {{#navEnrolled}}active{{/navEnrolled}}">Enrolled</a>
        <a href="/student/timetable" class="nav-link {{#navTimetable}}active{{/navTimetable}}">Timetable</a>
    </div>

    <div style="display: flex; align-items: center; gap: 1rem;">
        <span style="font-size: 0.9rem; color: var(--muted);">👤 {{firstName}} {{lastName}}</span>
        <form method="post" action="/logout" style="margin:0;">
            <button class="btn-logout" type="submit">Sign Out</button>
        </form>
    </div>
</nav>

<div class="content">
    <div class="message-box">
        <div class="icon">🚧</div>
        <h2 style="margin: 0 0 0.5rem 0;">{{pageTitle}}</h2>
        <p style="color: var(--muted); line-height: 1.5; margin: 0;">
            This module is currently under development. Check back later as our engineering team rolls out the next update!
        </p>
    </div>
</div>

</body>
</html>