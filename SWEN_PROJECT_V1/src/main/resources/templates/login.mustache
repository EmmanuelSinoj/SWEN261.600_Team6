<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <title>UniEnroll • Login</title>
    <style>
        :root{
            --bg:#0b1220;
            --card:#111a2e;
            --text:#e9eefc;
            --muted:#a9b4d0;
            --accent:#7c5cff;
            --accent2:#22c55e;
            --danger:#ef4444;
            --border:rgba(255,255,255,.10);
        }
        *{box-sizing:border-box}
        body{
            margin:0;
            font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
            background: radial-gradient(1000px 600px at 20% 10%, rgba(124,92,255,.35), transparent 60%),
            radial-gradient(900px 550px at 85% 25%, rgba(34,197,94,.25), transparent 55%),
            var(--bg);
            color:var(--text);
            min-height:100vh;
            display:flex;
            align-items:center;
            justify-content:center;
        }
        .login-card{
            width:100%;
            max-width:420px;
            border:1px solid var(--border);
            border-radius:20px;
            background: rgba(17,26,46,.85);
            backdrop-filter: blur(12px);
            padding:40px;
        }
        .brand{
            text-align:center;
            margin-bottom:32px;
        }
        .brand-icon{
            width:56px;
            height:56px;
            background: linear-gradient(135deg, var(--accent), #3b82f6);
            border-radius:16px;
            display:inline-flex;
            align-items:center;
            justify-content:center;
            font-size:28px;
            margin-bottom:16px;
        }
        .brand h1{
            margin:0;
            font-size:24px;
            font-weight:800;
            letter-spacing:0.5px;
        }
        .brand p{
            margin:6px 0 0;
            color:var(--muted);
            font-size:14px;
        }
        .input{
            width:100%;
            padding:14px 16px;
            border-radius:12px;
            border:1px solid var(--border);
            background: rgba(0,0,0,.25);
            color:var(--text);
            outline:none;
            font-size:15px;
            margin-bottom:12px;
            transition:border-color 0.2s;
        }
        .input:focus{border-color: var(--accent)}
        .btn{
            width:100%;
            padding:14px;
            border:1px solid transparent;
            border-radius:12px;
            cursor:pointer;
            font-weight:700;
            font-size:15px;
            background: linear-gradient(90deg, var(--accent), #3b82f6);
            color:white;
            transition:opacity 0.2s, transform 0.1s;
        }
        .btn:hover{opacity:0.9}
        .btn:active{transform: translateY(1px)}
        .msg{
            padding:12px 16px;
            border-radius:12px;
            border:1px solid var(--border);
            background: rgba(255,255,255,.06);
            color: var(--muted);
            margin-bottom:16px;
            font-size:14px;
            text-align:center;
        }
        .msg.error{
            border-color: rgba(239,68,68,.35);
            background: rgba(239,68,68,.12);
            color: #fecaca;
        }
        .footer{
            margin-top:24px;
            text-align:center;
            color:var(--muted);
            font-size:12px;
        }
    </style>
</head>
<body>
<div class="login-card">
    <div class="brand">
        <div class="brand-icon">🎓</div>
        <h1>UniEnroll</h1>
        <p>Academic Portal</p>
    </div>

    {{#error}}<div class="msg error">Invalid credentials</div>{{/error}}
    {{#logout}}<div class="msg">Session ended</div>{{/logout}}

    <form method="post" action="/login">
        <input class="input" name="email" type="email" placeholder="Email address" required autofocus />
        <input class="input" name="password" type="password" placeholder="Password" required />
        <button class="btn" type="submit">Sign In</button>
    </form>

    <div class="footer">
        Secure access • Admin & Student portals
    </div>
</div>
</body>
</html>