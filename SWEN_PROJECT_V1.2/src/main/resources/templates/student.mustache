<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>UniEnroll • Course Catalog</title>
    <style>
        :root{
            --bg:#0b1220;
            --card:#111a2e;
            --text:#e9eefc;
            --muted:#a9b4d0;
            --accent:#7c5cff;
            --accent2:#22c55e;
            --danger:#ef4444;
            --warning:#f59e0b;
            --border:rgba(255,255,255,.10);
        }
        *{box-sizing:border-box}
        body{
            margin:0;
            font-family: system-ui, -apple-system, sans-serif;
            background: var(--bg);
            color:var(--text);
            min-height:100vh;
        }
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.5rem 2rem;
            background: rgba(17,26,46,.95);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(10px);
        }
        .nav-brand { font-size: 1.25rem; font-weight: bold; color: var(--text); text-decoration: none; }
        .nav-brand span { color: var(--accent); }

        .nav-links { display: flex; gap: 1.5rem; }
        .nav-link {
            color: var(--muted);
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 500;
            padding: 0.5rem 0;
            border-bottom: 2px solid transparent;
            transition: all 0.2s;
        }
        .nav-link:hover { color: var(--text); }
        .nav-link.active { color: var(--text); border-bottom-color: var(--accent); }
        .layout {
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 2rem;
            padding: 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }
        .sidebar {
            background: rgba(17,26,46,.85);
            padding: 1.5rem;
            border-radius: 16px;
            border: 1px solid var(--border);
            height: fit-content;
        }
        .form-group { margin-bottom: 1rem; }
        label { display: block; margin-bottom: 0.5rem; font-size: 0.9rem; color: var(--muted); }
        input[type="text"], select {
            width: 100%;
            padding: 0.75rem;
            border-radius: 8px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            color: white;
        }
        select option {
            background-color: var(--bg);
            color: var(--text);
        }
        .btn {
            width: 100%;
            padding: 0.75rem;
            background: var(--accent);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            margin-top: 1rem;
            transition: all 0.2s;
        }
        .btn:hover { background: #6b4cf0; }

        /* New styling for disabled buttons */
        .btn-disabled {
            background: rgba(255,255,255,0.1);
            color: var(--muted);
            cursor: not-allowed;
        }
        .btn-disabled:hover {
            background: rgba(255,255,255,0.1);
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.5rem;
        }
        .course-card {
            background: rgba(17,26,46,.85);
            padding: 1.5rem;
            border-radius: 16px;
            border: 1px solid var(--border);
            position: relative;
            display: flex;
            flex-direction: column;
        }
        .badge {
            position: absolute;
            top: 1rem;
            right: 1rem;
            padding: 0.25rem 0.75rem;
            border-radius: 99px;
            font-size: 0.8rem;
            font-weight: bold;
        }
        .badge.open { background: rgba(34,197,94,0.2); color: var(--accent2); }
        .badge.waitlist { background: rgba(245,158,11,0.2); color: var(--warning); }
        .badge.full { background: rgba(239,68,68,0.2); color: var(--danger); }

        .course-code { color: var(--accent); font-weight: bold; font-size: 0.9rem; margin-bottom: 0.25rem; }
        .course-title { font-size: 1.25rem; font-weight: bold; margin: 0 0 1rem 0; }
        .detail { color: var(--muted); font-size: 0.9rem; margin-bottom: 0.5rem; }

        .btn-logout { background: transparent; color: var(--muted); border: 1px solid var(--border); padding: 0.5rem 1rem; border-radius: 8px; cursor: pointer; }
    </style>
</head>
<body>

<nav class="navbar">
    <a href="/student" class="nav-brand">Uni<span>Enroll</span></a>

    <div class="nav-links">
        <a href="/student" class="nav-link {{#navCatalog}}active{{/navCatalog}}">Catalog</a>
        <a href="/student/cart" class="nav-link {{#navCart}}active{{/navCart}}">Cart</a>
        <a href="/student/enrolled" class="nav-link {{#navEnrolled}}active{{/navEnrolled}}">Enrolled</a>
        <a href="/student/timetable" class="nav-link {{#navTimetable}}active{{/navTimetable}}">Timetable</a>
    </div>

    <div style="display: flex; align-items: center; gap: 1rem;">
        <span style="font-size: 0.9rem; color: var(--muted);">👤 {{firstName}} {{lastName}}</span>
        <form method="post" action="/logout" style="margin:0;">
            <button class="btn-logout" type="submit" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">Sign Out</button>
        </form>
    </div>
</nav>

<div class="layout">
    <aside class="sidebar">
        <h3 style="margin-top: 0;">Filters</h3>
        <form method="get" action="/student" id="searchForm">

            <div class="form-group">
                <label>Search (Code or Title)</label>
                <input type="text" name="query" id="query" placeholder="e.g. SWEN or Software">
            </div>

            <div class="form-group">
                <label>Course Level</label>
                <select name="level" id="level">
                    <option value="">All Levels</option>
                    <option value="100">100 - Freshman</option>
                    <option value="200">200 - Sophomore</option>
                    <option value="300">300 - Junior</option>
                    <option value="400">400 - Senior</option>
                    <option value="500">500 - Graduate</option>
                    <option value="600">600 - Advanced Graduate</option>
                </select>
            </div>

            <div class="form-group">
                <label>Professor</label>
                <input type="text" name="professor" id="professor" placeholder="e.g. Smith">
            </div>

            <div class="form-group">
                <label>Delivery Mode</label>
                <select name="mode" id="mode">
                    <option value="">Any Mode</option>
                    <option value="IN_PERSON">In-Person</option>
                    <option value="ONLINE">Online</option>
                    <option value="HYBRID">Hybrid</option>
                </select>
            </div>

            <div class="form-group">
                <label>Days</label>
                <select name="days" id="days">
                    <option value="">Any Days</option>
                    <option value="MON">Monday</option>
                    <option value="TUE">Tuesday</option>
                    <option value="WED">Wednesday</option>
                    <option value="THU">Thursday</option>
                    <option value="FRI">Friday</option>
                </select>
            </div>

            <button type="submit" class="btn">Apply Filters</button>
            <a href="/student" style="display:block; text-align:center; color:var(--muted); margin-top:1rem; font-size:0.9rem; text-decoration:none;">Clear Filters</a>
        </form>
    </aside>

    <main>
        {{#successMessage}}
            <div style="background: rgba(34,197,94,0.15); color: var(--accent2); border: 1px solid rgba(34,197,94,0.35); padding: 1rem; border-radius: 10px; margin-bottom: 1rem;">
                {{successMessage}}
            </div>
        {{/successMessage}}

        {{#errorMessage}}
            <div style="background: rgba(239,68,68,0.15); color: #fca5a5; border: 1px solid rgba(239,68,68,0.35); padding: 1rem; border-radius: 10px; margin-bottom: 1rem;">
                {{errorMessage}}
            </div>
        {{/errorMessage}}

        <div class="grid">
            {{#sections}}
                <div class="course-card">
                    {{#isOpen}}<div class="badge open">OPEN</div>{{/isOpen}}
                    {{#isWaitlist}}<div class="badge waitlist">WAITLIST</div>{{/isWaitlist}}
                    {{#isFull}}<div class="badge full">FULL</div>{{/isFull}}

                    <div class="course-code">{{course.code}} ({{course.credits}} CR)</div>
                    <h3 class="course-title">{{course.title}}</h3>

                    <div class="detail">👨‍🏫 {{professor}}</div>
                    <div class="detail">📅 {{daysString}} {{startTime}} - {{endTime}}</div>
                    <div class="detail">💻 Mode: {{deliveryMode}}</div>
                    <div class="detail" style="margin-top:auto; font-size:0.8rem; padding-top:1rem;">
                        Seats: <strong>{{enrolledCount}}/{{capacity}}</strong> |
                        Waitlist: <strong>{{waitlistCount}}/10</strong>
                    </div>

                    <form method="post" action="/student/cart/add" style="margin-top: 1rem;">
                        <input type="hidden" name="sectionId" value="{{id}}">

                        {{#isFull}}
                            <button class="btn btn-disabled" type="submit" disabled>Section Full</button>
                        {{/isFull}}

                        {{^isFull}}
                            <button class="btn" type="submit">Add to Cart 🛒</button>
                        {{/isFull}}
                    </form>
                </div>
            {{/sections}}

            {{^sections}}
                <div style="grid-column: 1 / -1; text-align: center; color: var(--muted); padding: 3rem;">
                    <h3>No courses found</h3>
                    <p>Try adjusting your search filters.</p>
                </div>
            {{/sections}}
        </div>
    </main>
</div>

<script>
    const params = new URLSearchParams(window.location.search);
    document.getElementById('query').value = params.get('query') || '';
    document.getElementById('level').value = params.get('level') || '';
    document.getElementById('professor').value = params.get('professor') || '';
    document.getElementById('mode').value = params.get('mode') || '';
    document.getElementById('days').value = params.get('days') || '';
</script>
</body>
</html>